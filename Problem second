// Design a class called Date. The class should store a date in three integers: month, day,
// and year. There should be member functions to print the date in the following forms:
// 12/25/10
// December 25, 2010
// 25 December 2010
// Demonstrate the class by writing a complete program implementing it.
// Input Validation: Do not accept values for the day greater than 31 or less than 1. Do
// not accept values for the month greater than 12 or less than 1.
#include <iostream>
using namespace std;
class Date
{
private:
    int date, month, year;
    string monthname[12] = {"January", "February", "March", "April", "May", "June",
                            "July", "August", "September", "October", "November", "December"};

public:
    Date(int d, int m, int y)
    {
        //  input validation for month
        if (m >= 1 && m <= 12)
        {
            month = m;
        }
        else
        {
            cout << " setting month to 1";
            month = 1;
        }

        //   input validation for date
        if (d >= 1 && d <= 31)
        {
            date = d;
        }
        else
        {
            cout << " setting date to 1";
            date = 1;
        }
        year = y;
    }

    // format 1
    void format_1()
    {
        cout << " The date will be printed according to the format  of  12/25/10 " << endl;
        cout << month << "/" << date << "/" << year << endl;
    }

    // format 2
    void format_2()
    {
        cout << " The date will be printed according to the format  of  December 25, 2010 " << endl;
        cout << monthname[month - 1] << " " << date << "," << " " << year << endl;
    }

    // format 3
    void format_3()
    {
        cout << " The date will be printed according to the format  of  25 December 2010 " << endl;
        cout << date << " " << monthname[month - 1] << " " << year << endl;
    }
};

int main()
{
    int d, m, y;

    cout << "Enter day (1-31): ";
    cin >> d;

    cout << "Enter month (1-12): ";
    cin >> m;

    cout << "Enter year: ";
    cin >> y;

    Date date(d, m, y);
    date.format_1();
    date.format_2();
    date.format_3();

    return 0;
}
